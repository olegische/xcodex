{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist-types",
    "allowImportingTsExtensions": true,
    "noCheck": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
